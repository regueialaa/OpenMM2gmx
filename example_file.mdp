; file.mdp - Just for generating the tpr file , no dynamics will be performed

integrator              = steep     ; No dynamics, 
nsteps                  = 0         
cutoff-scheme           = Verlet
ns_type		            = grid		
nstlist                 = 1
rlist                   = 1.0
coulombtype             = PME
rcoulomb                = 1.0
vdwtype                 = Cut-off
rvdw                    = 1.0
pbc                     = xyz